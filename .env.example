# Supabase（公開，可提交）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_key

# 伺服器端專用，請在 Vercel 設定，勿提交真實值
SUPABASE_SERVICE_ROLE_KEY=your_secret_key

# 可選：種子腳本寫入論壇貼文時需要
SUPABASE_DB_PASSWORD=your_database_password

# 可選：種子腳本建立假帳號時的預設密碼（優先於內建開發預設）
# SEED_DEFAULT_PASSWORD=your_local_seed_password

# 可選：VOID GACHA 上傳腳本（npm run upload:void-gacha）
# VOID_GACHA_ZIP_PATH=C:\path\to\VOID.zip
# VOID_GACHA_GAME_ID=1
# 設為 true 時允許自動覆蓋仍指向 void-gacha-preview.html 的 game_url
# VOID_GACHA_REPLACE_PREVIEW=true

# 可選：部署後的網站網址（用於解析 /covers 等相對路徑）
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# 可選：Footer 社群 icon 連結（未設定時預設跳至各平台官網，如 youtube.com）
# NEXT_PUBLIC_SOCIAL_X_URL=https://x.com/your-handle
# NEXT_PUBLIC_SOCIAL_GITHUB_URL=https://github.com/your-org
# NEXT_PUBLIC_SOCIAL_DISCORD_URL=https://discord.gg/your-invite
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=https://instagram.com/your-handle
# NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=https://youtube.com/@your-channel
# NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=https://facebook.com/your-page
# NEXT_PUBLIC_SOCIAL_BILIBILI_URL=https://space.bilibili.com/your-id
# NEXT_PUBLIC_SOCIAL_DOUYIN_URL=https://www.douyin.com/user/your-id
# NEXT_PUBLIC_SOCIAL_TIKTOK_URL=https://www.tiktok.com/@your-handle

# 可選：Google Analytics 4（設定後啟用 client-side 事件追蹤）
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# 可選：瀏覽器推播（Web Push — 設定頁可訂閱與測試推播）
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:support@your-domain.com

# --- Vercel Production 上線狀態（2026-07 複檢）---
# 已設定：Supabase、CRON_SECRET、Stripe live、PLATFORM_PREVIEW_MODE=false
# 尚未設定（可之後補）：RESEND_API_KEY、EMAIL_FROM、VAPID_*、NEXT_PUBLIC_GA_MEASUREMENT_ID、WEBSUB_HUB_URL
# 檢查：npm run check:env（本機）／ npx vercel env ls production

# Stripe（金流 Phase B — 伺服器端專用，勿提交）
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_CONNECT_COUNTRY=HK
# 設為 true 才啟用真實付款／Connect onboarding（預設預覽模式）
# STRIPE_PAYMENTS_LIVE=false
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# 平台預覽模式（跳過 Resend／Stripe 真實金流；Cron 仍會跑但不寄信）
# 設為 false 且配置 Resend + STRIPE_PAYMENTS_LIVE=true 即進入正式模式
PLATFORM_PREVIEW_MODE=true

# Email 收據（Resend — 打賞成功後寄送）
# RESEND_API_KEY=re_...          # Sending access（正式寄信用）
# RESEND_ADMIN_API_KEY=re_...    # Full access（setup:resend-domain 用，可選）
# CLOUDFLARE_API_TOKEN=...       # 可選，自動寫入 DNS（Zone:DNS:Edit）
# EMAIL_FROM=RainyNightFrog <receipts@your-domain.com>

# 可選：Vercel Cron 驗證（每週論壇摘要寄信）
# CRON_SECRET=generate_a_long_random_string

# 可選：Email 退訂連結簽章（預設沿用 CRON_SECRET）
# EMAIL_UNSUBSCRIBE_SECRET=generate_a_long_random_string

# 可選：WebSub Hub（Atom feed 更新推送，例如 Google PubSubHubbub）
# WEBSUB_HUB_URL=https://pubsubhubbub.appspot.com/
# 訂閱回調：/api/websub/callback（Cron 每週續訂：/api/cron/websub-subscribe）

# 可選：npm run setup:google:finish 用（勿提交）
# SUPABASE_ACCESS_TOKEN=從 https://supabase.com/dashboard/account/tokens 建立
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# 可選：npm run setup:discord:finish 用（勿提交）
# DISCORD_OAUTH_CLIENT_ID=
# DISCORD_OAUTH_CLIENT_SECRET=

# 可選：npm run setup:github:apply 用（勿提交）
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# 可選：npm run setup:twitch:apply 用（勿提交）
# TWITCH_OAUTH_CLIENT_ID=
# TWITCH_OAUTH_CLIENT_SECRET=
